# =====================================================
# Eteba Chat — Variables de Entorno
# =====================================================
# Copia este archivo como .env.local y rellena los valores reales.
# NUNCA subas .env.local a GitHub.

# --- InsForge (Base de datos Postgres + SDK) ---
INSFORGE_BASE_URL=https://TU_APPKEY.us-east.insforge.app
INSFORGE_API_KEY=ik_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# --- Postgres (conexión nativa) ---
DATABASE_URL=postgresql://postgres:PASSWORD@TU_APPKEY.us-east.database.insforge.app:5432/insforge?sslmode=require

# --- IA (Gemini API — Google AI Studio) ---
GEMINI_API_KEY=AIzaSyXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# --- OpenRouter (opcional/backup) ---
OPENROUTER_API_KEY=sk-or-v1-xxx

# --- Proxy PHP para MySQL externo (producción) ---
ROTTERI_PROXY_URL=https://tu-sitio.com/api/chat-proxy.php
ROTTERI_PROXY_TOKEN=TU_TOKEN_SECRETO_AQUI

# --- Google OAuth 2.0 ---
GOOGLE_CLIENT_ID=XXXXX.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-XXXXXXXXXXXXX

# --- Connector Encryption (AES-256-GCM for connector tokens at rest) ---
# Generate with: openssl rand -hex 32
CONNECTOR_ENCRYPTION_KEY=# 64-char hex string (32 random bytes): openssl rand -hex 32

# --- Puerto (Render lo asigna automáticamente) ---
# PORT=3000
