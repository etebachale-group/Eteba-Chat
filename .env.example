# =====================================================
# Eteba Chat — Variables de entorno de ejemplo
# =====================================================
# Copia este archivo como .env.local y rellena los valores reales
# NUNCA subas .env.local a GitHub

# --- InsForge (Base de datos Postgres + SDK) ---
INSFORGE_BASE_URL=https://TU_APPKEY.us-east.insforge.app
INSFORGE_API_KEY=ik_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# --- Postgres (InsForge) ---
DATABASE_URL=postgresql://postgres:TU_PASSWORD@TU_APPKEY.us-east.database.insforge.app:5432/insforge?sslmode=require

# --- OpenRouter (LLM gratuito) ---
OPENROUTER_API_KEY=sk-or-v1-XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# --- Proxy PHP para MySQL de Rotteri (solo en producción) ---
# URL del archivo chat-proxy.php en el hosting de rotteri.com
ROTTERI_PROXY_URL=https://rotteri.com/api/chat-proxy.php
# Token secreto compartido entre este backend y el proxy PHP
ROTTERI_PROXY_TOKEN=GENERA_UN_TOKEN_SECRETO_AQUI
